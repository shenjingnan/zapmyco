{
  "name": "@shenjingnan/ai-typescript-starter",
  "version": "0.4.5",
  "description": "AI 原生的 TypeScript 启动模板，专为 AI 辅助开发时代打造",
  "exports": "./src/index.ts",
  "tasks": {
    "dev": "deno run --watch src/index.ts",
    "test": "deno test",
    "test:coverage": "deno test --coverage && deno coverage",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/",
    "check:all": "deno fmt --check && deno lint && deno check src/ && deno test"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  },
  "publish": {
    "exclude": [
      ".agents",
      ".claude",
      ".githooks",
      ".github",
      "coverage",
      "docs",
      "examples",
      "CHANGELOG.md",
      "AGENTS.md",
      "src/**/*_test.ts"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true
  }
}
