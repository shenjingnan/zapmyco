{
  "name": "zapmyco",
  "version": "0.1.0",
  "description": "AI 原生并行任务编排系统 -- AI 总管 (Personal AI Chief of Staff)",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "zapmyco": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./protocol": {
      "import": "./dist/protocol/index.mjs",
      "types": "./dist/protocol/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/cli/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint",
    "check:fix": "pnpm run typecheck && pnpm run lint:fix && pnpm run format",
    "spellcheck": "cspell \"**/*.ts\" \"**/*.md\"",
    "prepare": "husky",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta --ci",
    "release:dry": "release-it --dry-run --ci",
    "release:patch": "release-it patch --ci",
    "release:minor": "release-it minor --ci",
    "release:major": "release-it major --ci"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "task",
    "parallel",
    "cli",
    "typescript",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shenjingnan/zapmyco.git"
  },
  "bugs": {
    "url": "https://github.com/shenjingnan/zapmyco/issues"
  },
  "homepage": "https://github.com/shenjingnan/zapmyco#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.9.0",
    "@mariozechner/pi-ai": "^0.70.5",
    "@mariozechner/pi-tui": "^0.70.2",
    "chalk": "^5.4.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.1",
    "eventemitter3": "^5.0.1",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.0",
    "cspell": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "release-it": "^19.2.4",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": ">=5.3.0",
      "undici": ">=6.24.0"
    }
  }
}
